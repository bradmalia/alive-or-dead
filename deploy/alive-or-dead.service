[Unit]
Description=Alive or Dead FastAPI app
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/alive-or-dead
Environment=APP_BASE_PATH=/alive-or-dead
EnvironmentFile=/home/ubuntu/alive-or-dead/.env
ExecStart=/home/ubuntu/alive-or-dead/venv/bin/python -m uvicorn main:app --host 127.0.0.1 --port 8001 --proxy-headers --forwarded-allow-ips=127.0.0.1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
